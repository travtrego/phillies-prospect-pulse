  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "update:news": "node scripts/update-news.mjs",
    "update:stats": "node scripts/update-stats.mjs",
    "update:promotions": "node scripts/update-promotions.mjs",
    "update:injuries": "node scripts/update-injuries.mjs",
    "update:rankings": "node scripts/update-rankings.mjs",
