    "test:genie": "tsx --test tests/genie.test.ts tests/ranking.test.ts",
    "audit:genie": "node scripts/audit-genie.mjs",
    "audit:ui": "node scripts/audit-ui.mjs",
    "audit:assignments": "node scripts/audit-assignments.mjs",
    "backtest:rankings": "node scripts/backtest-rankings.mjs",
